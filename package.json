{
  "name": "gameplan-turbo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron-dist/electron/main.js",
  "author": "Gameplan Turbo contributors",
  "description": "Local-first game design operating system for AI-assisted builders",
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/howlshot/gameplan-turbo.git"
  },
  "keywords": [
    "game-design",
    "preproduction",
    "ai",
    "game-development",
    "open-source",
    "developer-tools"
  ],
  "scripts": {
    "dev": "vite",
    "desktop:dev": "node scripts/desktop-dev.mjs",
    "desktop:build": "node scripts/desktop-builder.mjs --dir --mac --publish never",
    "desktop:dist": "node scripts/desktop-builder.mjs --mac dmg zip --publish never",
    "codex:bridge": "node scripts/codex-bridge.mjs",
    "claude:bridge": "node scripts/claude-bridge.mjs",
    "typecheck": "tsc -b --pretty false",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "electron-builder", "electron-winstaller"]
  },
  "build": {
    "appId": "com.gameplanturbo.desktop",
    "productName": "Gameplan Turbo",
    "disableDefaultIgnoredFiles": true,
    "directories": {
      "output": "release"
    },
    "asarUnpack": ["scripts/*.mjs"],
    "files": ["dist/**/*", "electron-dist/**/*", "package.json", "node_modules/**/*"],
    "icon": "build-resources/gameplan-turbo.icns",
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": ["codex-bridge.mjs", "claude-bridge.mjs"]
      },
      {
        "from": "public",
        "to": "public",
        "filter": ["gameplan-turbo-icon.png"]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build-resources/gameplan-turbo.icns",
      "target": ["dmg", "zip"]
    },
    "dmg": {
      "icon": "build-resources/gameplan-turbo.icns"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/generative-ai": "^0.24.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "jszip": "^3.10.1",
    "openai": "^6.32.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^4.1.0"
  }
}
